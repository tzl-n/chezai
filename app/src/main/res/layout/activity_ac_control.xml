<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:orientation="vertical"
    tools:context=".AcControlActivity">

    <!-- 顶部栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="空调设置"
            android:textColor="#000000"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/btn_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_close_black"
                android:contentDescription="关闭" />
        </LinearLayout>
    </LinearLayout>

    <!-- 电池智能预热设置 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="16dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="电池智能预热设置 >>"
            android:textColor="#666666"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 温度调节区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="20dp"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_temp_minus"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="-"
            android:textColor="#000000"
            android:textSize="48sp"
            android:gravity="center" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginLeft="30dp"
            android:layout_marginRight="30dp">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="23.5"
                android:textColor="#000000"
                android:textSize="48sp"
                android:textStyle="bold" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="°C"
                android:textColor="#000000"
                android:textSize="24sp"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_temp_plus"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:text="+"
            android:textColor="#000000"
            android:textSize="48sp"
            android:gravity="center" />
    </LinearLayout>

    <!-- 功能开关列表 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingRight="20dp"
        android:layout_marginTop="20dp">

        <!-- 方向盘加热 -->
        <LinearLayout
            android:id="@+id/btn_steering_heat"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="方向盘加热"
                android:textColor="#000000"
                android:textSize="16sp" />
            <ImageView
                android:id="@+id/icon_steering_heat"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_check_green"
                android:contentDescription="已开启" />
        </LinearLayout>

        <!-- 座椅通风 -->
        <LinearLayout
            android:id="@+id/btn_seat_vent"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="座椅通风"
                android:textColor="#000000"
                android:textSize="16sp" />
            <ImageView
                android:id="@+id/icon_seat_vent"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_check_green"
                android:contentDescription="已开启" />
        </LinearLayout>

        <!-- 主驾副驾选择 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:id="@+id/btn_driver"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginRight="10dp"
                android:background="@drawable/border_green_round"
                android:gravity="center"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="主驾"
                    android:textColor="#00D4AA"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btn_passenger"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginLeft="10dp"
                android:background="@drawable/border_green_round"
                android:gravity="center"
                android:orientation="horizontal">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="副驾"
                    android:textColor="#00D4AA"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 座椅加热 -->
        <LinearLayout
            android:id="@+id/btn_seat_heat"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="16dp">
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="座椅加热"
                android:textColor="#999999"
                android:textSize="16sp" />
            <ImageView
                android:id="@+id/icon_seat_heat"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_uncheck_gray"
                android:contentDescription="未开启" />
        </LinearLayout>
    </LinearLayout>

    <!-- 底部按钮 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="20dp"
        android:layout_marginTop="30dp">

        <LinearLayout
            android:id="@+id/btn_add_reserve"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginRight="12dp"
            android:background="@drawable/gray_round"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="加入预约"
                android:textColor="#666666"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btn_turn_on"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginLeft="12dp"
            android:background="@drawable/green_round"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="立即开启"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>