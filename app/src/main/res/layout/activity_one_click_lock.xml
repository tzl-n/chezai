<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    tools:context=".OneClickLockActivity">

    <!-- 顶部导航栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="24dp">

        <!-- 返回按钮 -->
        <LinearLayout
            android:id="@+id/btn_back"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="#FFFFFF"
            android:gravity="center"
            android:elevation="4dp"
            android:layout_marginRight="24dp">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_back_arrow"
                android:contentDescription="返回" />
        </LinearLayout>

        <!-- 车辆信息 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="KLC 300E"
                android:textColor="#333333"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4MATIC AMG"
                android:textColor="#999999"
                android:textSize="14sp"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <View
            android:layout_width="80dp"
            android:layout_height="56dp" />
    </LinearLayout>

    <!-- 可滑动内容区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 信息卡片区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:paddingBottom="24dp">

                <!-- 路线卡片 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_round"
                    android:padding="20dp"
                    android:orientation="vertical"
                    android:elevation="4dp"
                    android:layout_marginRight="12dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_clock"
                        android:contentDescription="路线" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="路线"
                        android:textColor="#999999"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="397mi"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- 速度卡片 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_round"
                    android:padding="20dp"
                    android:orientation="vertical"
                    android:elevation="4dp"
                    android:layout_marginRight="12dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_motorcycle"
                        android:contentDescription="速度" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="速度"
                        android:textColor="#999999"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="136KTS"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- 油耗卡片 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_card_round"
                    android:padding="20dp"
                    android:orientation="vertical"
                    android:elevation="4dp">

                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_chip"
                        android:contentDescription="油耗" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="油耗"
                        android:textColor="#999999"
                        android:textSize="12sp"
                        android:layout_marginTop="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="16.9KWH"
                        android:textColor="#333333"
                        android:textSize="15sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 车辆图片区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- 左切换按钮 -->
                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="#FFFFFF"
                    android:gravity="center"
                    android:layout_marginRight="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_back_arrow"
                        android:contentDescription="左切换" />
                </LinearLayout>

                <!-- 车辆图片 -->
                <ImageView
                    android:layout_width="300dp"
                    android:layout_height="450dp"
                    android:src="@drawable/img_8"
                    android:scaleType="fitCenter"
                    android:contentDescription="车辆图片" />

                <!-- 右切换按钮 -->
                <LinearLayout
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="#FFFFFF"
                    android:gravity="center"
                    android:layout_marginLeft="16dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_back_arrow"
                        android:contentDescription="右切换"
                        android:rotation="180" />
                </LinearLayout>
            </LinearLayout>

            <!-- 底部锁车按钮区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="24dp"
                android:paddingBottom="64dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:background="#E8E8E8"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <!-- 锁车按钮（选中状态） -->
                    <LinearLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="#FFFFFF"
                        android:gravity="center"
                        android:layout_marginLeft="4dp"
                        android:radius="36dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_lock"
                            android:contentDescription="锁车" />
                    </LinearLayout>

                    <!-- 分隔箭头 -->
                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_double_arrow"
                        android:contentDescription="分隔" />

                    <!-- 解锁按钮（未选中状态） -->
                    <LinearLayout
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:background="#CCCCCC"
                        android:gravity="center"
                        android:layout_marginRight="4dp"
                        android:radius="36dp">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_unlock"
                            android:contentDescription="解锁" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>