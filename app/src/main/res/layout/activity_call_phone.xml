<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A4D68">

    <!-- 顶部导航栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <!-- 返回按钮 -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            app:tint="#FFFFFF"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="返回" />

        <!-- 标题 -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="呼叫手机"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- 占位 -->
        <View
            android:layout_width="40dp"
            android:layout_height="40dp" />
    </LinearLayout>

    <!-- 主要内容 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <!-- 通话状态 -->
        <TextView
            android:id="@+id/tvCallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="正在通话"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <!-- 通话时长 -->
        <TextView
            android:id="@+id/tvCallDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="03:23"
            android:textColor="#FFFFFF"
            android:textSize="14sp" />

        <!-- 头像 -->
        <FrameLayout
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="24dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_call_circle" />

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_person"
                android:contentDescription="头像" />
        </FrameLayout>

        <!-- 电话号码 -->
        <TextView
            android:id="@+id/tvPhoneNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="132 0098 6890"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <!-- 运营商 -->
        <TextView
            android:id="@+id/tvCarrier"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="北京联通"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:alpha="0.7" />

    </LinearLayout>

    <!-- 功能按钮区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp"
        android:paddingBottom="32dp"
        android:paddingTop="16dp">

        <!-- 第一行功能按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- 录音 -->
            <LinearLayout
                android:id="@+id/btnRecord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_record"
                    app:tint="#FFFFFF"
                    android:alpha="0.7"
                    android:contentDescription="录音" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="录音"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:alpha="0.7" />
            </LinearLayout>

            <!-- 等待 -->
            <LinearLayout
                android:id="@+id/btnHold"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_hold"
                    app:tint="#FFFFFF"
                    android:alpha="0.7"
                    android:contentDescription="等待" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="等待"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:alpha="0.7" />
            </LinearLayout>

            <!-- 备忘录 -->
            <LinearLayout
                android:id="@+id/btnMemo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_memo"
                    app:tint="#FFFFFF"
                    android:alpha="0.7"
                    android:contentDescription="备忘录" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="备忘录"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:alpha="0.7" />
            </LinearLayout>
        </LinearLayout>

        <!-- 第二行功能按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <!-- 添加通话 -->
            <LinearLayout
                android:id="@+id/btnAddCall"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_add_call"
                    app:tint="#FFFFFF"
                    android:alpha="0.7"
                    android:contentDescription="添加通话" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="添加通话"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:alpha="0.7" />
            </LinearLayout>

            <!-- 静音 -->
            <LinearLayout
                android:id="@+id/btnMute"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_mute"
                    app:tint="#FFFFFF"
                    android:alpha="0.7"
                    android:contentDescription="静音" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="静音"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:alpha="0.7" />
            </LinearLayout>

            <!-- 联系人 -->
            <LinearLayout
                android:id="@+id/btnContacts"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_contacts"
                    app:tint="#FFFFFF"
                    android:alpha="0.7"
                    android:contentDescription="联系人" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="联系人"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:alpha="0.7" />
            </LinearLayout>
        </LinearLayout>

        <!-- 底部控制栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- 扬声器 -->
            <ImageView
                android:id="@+id/btnSpeaker"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_speaker"
                app:tint="#FFFFFF"
                android:alpha="0.7"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="扬声器" />

            <!-- 挂断按钮 -->
            <Button
                android:id="@+id/btnHangup"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"
                android:background="@drawable/bg_button_hangup"
                android:text="挂断"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold" />

            <!-- 更多 -->
            <ImageView
                android:id="@+id/btnMore"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_more_options"
                app:tint="#FFFFFF"
                android:alpha="0.7"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="更多" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
