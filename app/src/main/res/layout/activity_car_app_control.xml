<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5"
    tools:context=".CarAppControlActivity">

    <!-- 数据更新时间 -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="数据更新于：2023年3月12号 14:09:23"
        android:textColor="#999999"
        android:textSize="12sp"
        android:padding="16dp" />

    <!-- 主内容区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 车辆信息和电量 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="24dp">

                <!-- 左侧信息 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <!-- 车辆名称 -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="筋斗云汽车"
                        android:textColor="#333333"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <!-- 剩余电量 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="24dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="70%"
                            android:textColor="#333333"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginRight="16dp"
                            android:progress="70"
                            android:max="100"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:background="#E0E0E0"
                            android:progressDrawable="@drawable/bg_progress" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="剩余电量"
                            android:textColor="#999999"
                            android:textSize="12sp"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <!-- 可续航里程 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="20dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="234"
                                android:textColor="#333333"
                                android:textSize="30sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" KM"
                                android:textColor="#666666"
                                android:textSize="20sp" />
                        </LinearLayout>

                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="6dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginRight="16dp"
                            android:progress="60"
                            android:max="100"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:background="#E0E0E0"
                            android:progressDrawable="@drawable/bg_progress" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="可续航里程"
                            android:textColor="#999999"
                            android:textSize="12sp"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 右侧车辆图片 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="180dp"
                        android:layout_height="280dp"
                        android:src="@drawable/img_5"
                        android:scaleType="fitCenter"
                        android:contentDescription="车辆俯视图" />
                </LinearLayout>
            </LinearLayout>

            <!-- 功能按钮区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:paddingBottom="24dp">

                <!-- 寻车 -->
                <LinearLayout
                    android:id="@+id/btn_find_car"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_btn_square"
                    android:padding="16dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_car_search"
                        android:contentDescription="寻车" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="寻车"
                        android:textColor="#666666"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- 车锁 -->
                <LinearLayout
                    android:id="@+id/btn_lock"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_btn_square"
                    android:padding="16dp"
                    android:layout_marginLeft="12dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_car_lock"
                        android:contentDescription="车锁" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="车锁"
                        android:textColor="#666666"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- 空调 -->
                <LinearLayout
                    android:id="@+id/btn_ac"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_btn_square"
                    android:padding="16dp"
                    android:layout_marginLeft="12dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_ac_app"
                        android:contentDescription="空调" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="空调"
                        android:textColor="#666666"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>

                <!-- 更多 -->
                <LinearLayout
                    android:id="@+id/btn_more"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/bg_btn_square"
                    android:padding="16dp"
                    android:layout_marginLeft="12dp">

                    <ImageView
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@drawable/ic_more_app"
                        android:contentDescription="更多" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="更多"
                        android:textColor="#666666"
                        android:textSize="12sp"
                        android:layout_marginTop="8dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 地图导航按钮 -->
            <LinearLayout
                android:id="@+id/btn_navigation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="#E8EEF3"
                android:padding="20dp"
                android:layout_marginLeft="24dp"
                android:layout_marginRight="24dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_location_nav"
                    android:contentDescription="地图导航" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="地图导航"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:layout_marginLeft="12dp" />
            </LinearLayout>

            <!-- 标签切换区域 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="24dp">

                <!-- 车辆控制 -->
                <LinearLayout
                    android:id="@+id/tab_car_control"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/tab_car_control_icon"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_car_ctrl"
                        android:contentDescription="车辆控制" />

                    <TextView
                        android:id="@+id/tab_car_control_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="车辆控制"
                        android:textColor="#333333"
                        android:textSize="12sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- 环境调节 -->
                <LinearLayout
                    android:id="@+id/tab_env_control"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:id="@+id/tab_env_control_icon"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_env"
                        android:contentDescription="环境调节" />

                    <TextView
                        android:id="@+id/tab_env_control_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="环境调节"
                        android:textColor="#999999"
                        android:textSize="12sp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- 底部占位 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="80dp" />
        </LinearLayout>
    </ScrollView>

    <!-- 底部导航栏 -->
    <include layout="@layout/bottom_nav" />
</LinearLayout>